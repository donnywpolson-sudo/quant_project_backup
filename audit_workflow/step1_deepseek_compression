def compress_with_deepseek(full_code: str) -> str:
    prompt = f"""
Compress this trading system into minimal structured form.

Format:

DATA:
FEATURES:
LABEL:
LOGIC:
BACKTEST:
VALIDATION:
OPT:
RISK:

Rules:
- remove all code
- keep only core logic and assumptions
- max 1–2 lines per section
- no extra text, only structured output

System:
{full_code}
"""

    response = requests.post(
        DEEPSEEK_URL,
        headers={
            "Authorization": f"Bearer {DEEPSEEK_API_KEY}",
            "Content-Type": "application/json"
        },
        json={
            "model": MODEL,
            "messages": [
                {"role": "user", "content": prompt}
            ],
            "temperature": 0
        }
    )

    if response.status_code != 200:
        raise Exception(f"API Error: {response.text}")

    return response.json()["choices"][0]["message"]["content"]


