import subprocess

def run_git_command(cmd):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Error running: {cmd}\n{result.stderr}")
        exit(1)
    return result.stdout.strip()

# Get list of staged files
staged_files = run_git_command("git diff --cached --name-only").splitlines()

if not staged_files:
    print("No staged files found.")
    exit(0)

print(f"Found {len(staged_files)} staged files.\n")

for file in staged_files:
    print(f"Committing: {file}")

    # Create commit per file
    # First unstage everything
    run_git_command("git reset")

    # Stage only this file
    run_git_command(f'git add "{file}"')

    # Commit
    run_git_command(f'git commit -m "Add/update {file}"')

    # Optional: push after each commit
    # Uncomment if desired:
    # run_git_command("git push")

print("\n✅ Done committing all files individually!")