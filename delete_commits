import os
import subprocess
import sys

def run_cmd(cmd):
    result = subprocess.run(cmd, shell=True)
    if result.returncode != 0:
        print(f"❌ Failed: {cmd}")
        sys.exit(1)

def main():
    print("⚠️ WARNING: This will permanently delete ALL git history (no backup).")

    if not os.path.isdir(".git"):
        print("❌ Not a git repo")
        sys.exit(1)

    # Get remote and branch
    remote = subprocess.getoutput("git config --get remote.origin.url")
    branch = subprocess.getoutput("git branch --show-current") or "main"

    print(f"🌐 Remote: {remote}")
    print(f"🌿 Branch: {branch}")

    confirm = input("\nType 'RESET' to continue: ")
    if confirm != "RESET":
        print("❌ Cancelled")
        sys.exit(0)

    # Delete history
    print("\n🧹 Deleting .git...")
    run_cmd("rm -rf .git")

    # Reinit
    print("\n🔄 Recreating repo...")
    run_cmd("git init")
    run_cmd(f"git branch -M {branch}")
    run_cmd("git add .")
    run_cmd('git commit -m "Fresh start"')

    # Restore remote
    run_cmd(f"git remote add origin {remote}")

    confirm_push = input("\nType 'PUSH' to overwrite GitHub: ")
    if confirm_push != "PUSH":
        print("❌ Push cancelled")
        sys.exit(0)

    print("\n🚀 Force pushing...")
    run_cmd(f"git push -f origin {branch}")

    print("\n✅ Done. Repo history fully reset.")

if __name__ == "__main__":
    main()
