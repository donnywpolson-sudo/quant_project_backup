# Python environment and caches
__pycache__/
.venv/
*.pyc
*.pyo
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Project Data (Do not sync these)
output/cache/
futures/

# Secrets and Settings
.env
.DS_Store
*.log

# Generated by the pipeline at runtime
full_code.md                # auto‑generated snapshot (changes every run)
*.parquet                   # any temporary Parquet files (resampled streams, cache)
temp_*                      # temporary directories / files from resampling
*.tmp

# VS Code (optional – only if you don't want to share workspace settings)
.vscode/
*.code-workspace

# Jupyter notebooks (if any)
.ipynb_checkpoints/
*.ipynb

# OS metadata
Thumbs.db
desktop.ini

# --- Additional entries for quant pipeline ---
# Cache and model directories (from config)
cache/
models/

# Generated test fixtures (synthetic data)
tests/fixtures/
!tests/fixtures/.gitkeep   # optional, to keep the directory

# Serialized models / joblib files
*.pkl
*.joblib

# CSV outputs (if any written outside artifacts)
*.csv

# Coverage and test reports
.coverage
htmlcov/
.tox/

# IDE folders (if not already covered)
.idea/
*.swp
*.swo

# Databento API Key
.env